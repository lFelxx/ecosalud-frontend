# ═══════════════════════════════════════════════════════════════════
# Ecosalud Frontend — Variables de entorno
# ═══════════════════════════════════════════════════════════════════
# Copia este archivo como .env.local y rellena los valores reales.
# El archivo .env.local está en .gitignore — nunca lo versiones.
#
# En Vercel: define estas variables en Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════

# URL base del backend (sin barra final)
# Desarrollo local: http://localhost:8080/api
# Producción:       https://tu-backend.railway.app/api
VITE_API_URL=http://localhost:8080/api
